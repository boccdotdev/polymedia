{{ forms.checkboxGroupField({
    label: 'Default Allowed Providers'|t('polymedia'),
    instructions: 'Default provider restriction for new Polymedia fields. Empty means all providers allowed.'|t('polymedia'),
    id: 'defaultFieldAllowedProviders',
    name: 'defaultFieldAllowedProviders',
    values: settings.defaultFieldAllowedProviders,
    options: [
        { label: 'HLS', value: 'hls' },
        { label: 'DASH', value: 'dash' },
        { label: 'Shaka', value: 'shaka' },
        { label: 'Mux', value: 'mux' },
        { label: 'YouTube', value: 'youtube' },
        { label: 'Vimeo', value: 'vimeo' },
        { label: 'Spotify', value: 'spotify' },
        { label: 'TikTok', value: 'tiktok' },
        { label: 'Wistia', value: 'wistia' },
        { label: 'JW Player', value: 'jwplayer' },
        { label: 'Twitch', value: 'twitch' },
        { label: 'Cloudflare', value: 'cloudflare' },
        { label: 'PeerTube', value: 'peertube' },
        { label: 'Video.js', value: 'videojs' },
        { label: 'MP4/WebM/MOV', value: 'mp4' },
        { label: 'Audio', value: 'audio' },
    ],
    disabled: not allowAdminChanges,
}) }}

